# ═══════════════════════════════════════════════════════
#  VPS Control App - Environment Configuration
#  Copy to .env and fill in all values before deploying.
#  deploy.sh generates this automatically.
# ═══════════════════════════════════════════════════════

# ─── Domain & Traefik ───
DOMAIN=vps.example.com
CERT_RESOLVER=letsencrypt
TRAEFIK_NETWORK=traefik

# ─── Database ───
DB_HOST=db
DB_PORT=5432
DB_NAME=vpscontrol
DB_USER=vpscontrol
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://vpscontrol:CHANGE_ME_STRONG_PASSWORD@db:5432/vpscontrol?schema=public

# ─── Security ───
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_FOR_AES256

# ─── Admin Account (used by seed script on first run) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
