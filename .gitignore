# ═══════════════════════════════════════════════════
#  VPS Control App - .gitignore
# ═══════════════════════════════════════════════════

# ─── Dependencies ───
node_modules/
.pnp
.pnp.js

# ─── Next.js ───
.next/
out/

# ─── Production Build ───
build/
dist/

# ─── Environment & Secrets ───
.env
.env.local
.env.*.local
.env.example
.git-credentials

# ─── IDE & Editor ───
.agent/
.cursor/
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS Files ───
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Debug Logs ───
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Testing ───
tests/
coverage/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/
jest.config.*
vitest.config.*

# ─── Examples & Docs (non-essential) ───
examples/
.examples/

# ─── Prisma / SQLite ───
*.db
*.db-journal
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# ─── Deployment Artifacts ───
/tmp/vps-deployments/

# ─── Docker (local dev volumes) ───
docker-data/

# ─── TypeScript Build Cache ───
tsconfig.tsbuildinfo

# ─── SSL / SSH / Secrets ───
*.pem
*.key
*.crt
*.pfx
*.p12
id_rsa
id_ed25519
known_hosts

# ─── Runtime Uploads ───
uploads/
storage/
public/uploads/

# ─── Misc ───
*.tgz
*.log
.turbo

