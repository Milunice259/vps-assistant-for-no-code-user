// ═══════════════════════════════════════════════════
//  VPS Control App - Prisma Schema
//  Sensitive fields (SSH keys, passwords) are encrypted
//  at the application layer using AES-256-GCM.
// ═══════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Admin users ───
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?
  displayName  String?  @map("display_name")
  passwordHash String   @map("password_hash")
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ─── Security audit trail ───
model AuditLog {
  id        String   @id @default(cuid())
  action    String                          // e.g., "login", "container_stop", "deploy_git"
  userId    String?  @map("user_id")
  username  String   @default("system")
  target    String?                          // e.g., server name, container ID
  details   String?                          // extra context / JSON payload
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─── Application settings ───
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─── Notification channels ───
model NotificationChannel {
  id        String   @id @default(cuid())
  name      String                              // e.g., "My Discord"
  type      String                              // "discord" | "slack" | "telegram"
  webhookUrl String  @map("webhook_url")        // Webhook endpoint URL
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  alertRules AlertRule[]

  @@map("notification_channels")
}

// ─── Alert rules (threshold-based) ───
model AlertRule {
  id          String   @id @default(cuid())
  metric      String                              // "cpu" | "memory" | "disk"
  operator    String   @default("gt")             // "gt" | "lt"
  threshold   Float                               // e.g., 90.0 (percent)
  channelId   String   @map("channel_id")
  channel     NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  serverId    String?  @map("server_id")          // null = all servers
  enabled     Boolean  @default(true)
  lastFiredAt DateTime? @map("last_fired_at")
  cooldownMin Int      @default(15) @map("cooldown_min")  // minimum minutes between alerts
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("alert_rules")
}

// ─── Remote VPS connections ───
model Server {
  id            String     @id @default(cuid())
  name          String
  host          String
  port          Int        @default(22)
  username      String
  authMethod    AuthMethod @default(PASSWORD) @map("auth_method")
  encryptedKey  String?    @map("encrypted_key")  // AES-256-GCM encrypted SSH private key
  encryptedPass String?    @map("encrypted_pass") // AES-256-GCM encrypted SSH password
  isActive      Boolean    @default(true) @map("is_active")
  lastConnected DateTime?  @map("last_connected")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  apps        App[]
  deployments DeploymentLog[]

  @@map("servers")
}

// ─── Deployment history ───
model DeploymentLog {
  id            String       @id @default(cuid())
  repoUrl       String       @map("repo_url")
  branch        String       @default("main")
  detectedStack String       @map("detected_stack")
  status        DeployStatus @default(PENDING)
  logs          String
  domain        String?
  serverId      String?      @map("server_id")
  server        Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  commitHash    String?      @map("commit_hash")
  customPath    String?      @map("custom_path")
  encryptedEnv  String?      @map("encrypted_env") // AES-256-GCM encrypted JSON env vars
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("deployment_logs")
}

// ─── Tracked applications across servers ───
model App {
  id            String    @id @default(cuid())
  name          String
  containerId   String?   @map("container_id")
  containerName String?   @map("container_name")
  image         String?
  serverId      String    @map("server_id")
  server        Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  deploymentId  String?   @map("deployment_id")
  status        AppStatus @default(UNKNOWN)
  domain        String?

  // ── Resource Limits ──
  cpuLimit      Float?    @map("cpu_limit")        // CPU cores (e.g., 0.5 = half core)
  memoryLimit   Int?      @map("memory_limit")      // Memory limit in MB
  storageLimit  Int?      @map("storage_limit")     // Storage limit in MB

  // ── Environment Variables (AES-256-GCM encrypted JSON) ──
  encryptedEnv  String?   @map("encrypted_env")

  // ── Container Configuration ──
  restartPolicy String?   @map("restart_policy")    // always|unless-stopped|on-failure|no
  healthCheck   String?   @map("health_check")      // Health check command
  volumes       String?   @map("volumes")           // JSON array of volume mounts
  ports         String?   @map("ports")             // JSON array of port mappings

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  metrics       AppMetric[]
  envProfiles   EnvProfile[]

  @@map("apps")
}

// ─── Per-app resource metrics (time-series) ───
model AppMetric {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  cpuUsage  Float    @map("cpu_usage")     // percentage 0-100
  memUsage  Float    @map("mem_usage")     // MB used
  netIn     Float?   @map("net_in")        // bytes/s inbound
  netOut    Float?   @map("net_out")       // bytes/s outbound
  timestamp DateTime @default(now())

  @@index([appId, timestamp])
  @@map("app_metrics")
}

// ─── Env override profiles ───
model EnvProfile {
  id        String   @id @default(cuid())
  appId     String   @map("app_id")
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  name      String                         // e.g., "Production", "Debug", "Test"
  vars      String                         // JSON: {"KEY": "value", ...}
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([appId, name])
  @@map("env_profiles")
}

enum UserRole {
  ADMIN     // Full access — all actions
  OPERATOR  // Start/stop containers, deploy, view logs
  VIEWER    // Read-only dashboard access
}

enum AuthMethod {
  PASSWORD
  KEY
}

enum DeployStatus {
  PENDING
  CLONING
  BUILDING
  RUNNING
  FAILED
}

enum AppStatus {
  RUNNING
  STOPPED
  RESTARTING
  UNHEALTHY
  UNKNOWN
}
